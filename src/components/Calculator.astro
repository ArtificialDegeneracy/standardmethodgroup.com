<section class="calc-section">
  <div class="calc-inner">
    <div class="calc-inputs">
      <div class="input-group">
        <label for="hours">Hours per week spent on paperwork, status updates, and chasing information</label>
        <p class="input-hint">Think: filing, reporting, following up, re-entering data, compiling numbers someone already has</p>
        <div class="slider-row">
          <input type="range" id="hours" min="2" max="40" value="10" step="1" />
          <output for="hours" class="slider-value" id="hours-value">10 hrs</output>
        </div>
      </div>

      <div class="input-group">
        <label for="rate">What that time costs per hour</label>
        <p class="input-hint">The hourly rate of the person doing this work — you, your office manager, or whoever it falls to</p>
        <div class="rate-presets">
          <button class="rate-btn" data-rate="20">$20</button>
          <button class="rate-btn active" data-rate="25">$25</button>
          <button class="rate-btn" data-rate="30">$30</button>
          <button class="rate-btn" data-rate="35">$35</button>
          <button class="rate-btn" data-rate="40">$40</button>
        </div>
        <div class="rate-custom">
          <span>or enter your own:</span>
          <div class="custom-rate-wrap">
            <span class="dollar-sign">$</span>
            <input type="number" id="rate" min="15" max="300" value="25" />
          </div>
        </div>
      </div>
    </div>

    <div class="calc-results">
      <h3>What that adds up to</h3>

      <div class="result-row">
        <span class="result-label">Monthly hours on admin</span>
        <span class="result-number" id="monthly-hours">43</span>
      </div>

      <div class="result-row">
        <span class="result-label">Monthly cost</span>
        <span class="result-number" id="monthly-cost">$9,675</span>
      </div>

      <div class="result-row">
        <span class="result-label">Annual cost</span>
        <span class="result-number" id="annual-cost">$116,100</span>
      </div>

      <div class="result-divider"></div>

      <div class="result-recovery">
        <h3>What typically changes</h3>
        <p class="recovery-text">Businesses like yours typically recover <strong id="recovery-low">26</strong> to <strong id="recovery-high">32</strong> hours per month — roughly <strong id="savings-low">$1,290</strong> to <strong id="savings-high">$1,613</strong> back in your pocket.</p>
        <p class="recovery-annual">That's <strong id="annual-low">$15,480</strong> to <strong id="annual-high">$19,350</strong> per year in time your team gets back.</p>
      </div>
    </div>
  </div>

  <div class="calc-lead">
    <div class="calc-lead-inner">
      <h3>Want to talk through these numbers?</h3>
      <p>Book a 30-minute conversation and we'll walk through what's realistic for your business.</p>
      <a href="https://calendar.app.google/hH5ewNekVCHFKrcc9" target="_blank" rel="noopener" class="lead-book">Book a discovery conversation</a>
      <p class="lead-alt">or email your results to <a href="mailto:dan@standardmethodgroup.com">dan@standardmethodgroup.com</a></p>
    </div>
  </div>
</section>

<script>
  const hoursSlider = document.getElementById('hours') as HTMLInputElement;
  const rateInput = document.getElementById('rate') as HTMLInputElement;
  const rateBtns = document.querySelectorAll('.rate-btn');

  function formatCurrency(n: number): string {
    return '$' + n.toLocaleString('en-US', { maximumFractionDigits: 0 });
  }

  function calculate() {
    const hours = parseFloat(hoursSlider.value);
    const rate = parseFloat(rateInput.value) || 25;

    const monthlyHours = Math.round(hours * 4.33);
    const monthlyCost = monthlyHours * rate;
    const annualCost = monthlyCost * 12;

    const recoveryLowPct = 0.40;
    const recoveryHighPct = 0.50;

    const recoveryHoursLow = Math.round(monthlyHours * recoveryLowPct);
    const recoveryHoursHigh = Math.round(monthlyHours * recoveryHighPct);
    const savingsLow = Math.round(monthlyCost * recoveryLowPct);
    const savingsHigh = Math.round(monthlyCost * recoveryHighPct);
    const annualLow = savingsLow * 12;
    const annualHigh = savingsHigh * 12;

    // Update display
    (document.getElementById('hours-value') as HTMLElement).textContent = hours + ' hrs';
    (document.getElementById('monthly-hours') as HTMLElement).textContent = monthlyHours.toString();
    (document.getElementById('monthly-cost') as HTMLElement).textContent = formatCurrency(monthlyCost);
    (document.getElementById('annual-cost') as HTMLElement).textContent = formatCurrency(annualCost);
    (document.getElementById('recovery-low') as HTMLElement).textContent = recoveryHoursLow.toString();
    (document.getElementById('recovery-high') as HTMLElement).textContent = recoveryHoursHigh.toString();
    (document.getElementById('savings-low') as HTMLElement).textContent = formatCurrency(savingsLow);
    (document.getElementById('savings-high') as HTMLElement).textContent = formatCurrency(savingsHigh);
    (document.getElementById('annual-low') as HTMLElement).textContent = formatCurrency(annualLow);
    (document.getElementById('annual-high') as HTMLElement).textContent = formatCurrency(annualHigh);

  }

  hoursSlider.addEventListener('input', calculate);
  rateInput.addEventListener('input', calculate);

  rateBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      rateBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      rateInput.value = (btn as HTMLElement).dataset.rate || '25';
      calculate();
    });
  });

  // Sync: if user types a custom rate, deselect preset buttons
  rateInput.addEventListener('input', () => {
    const val = rateInput.value;
    rateBtns.forEach(btn => {
      btn.classList.toggle('active', (btn as HTMLElement).dataset.rate === val);
    });
  });

  // Initial calculation
  calculate();
</script>

