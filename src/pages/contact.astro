---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import ContactForm from '../components/ContactForm.astro';
import CTAStrip from '../components/CTAStrip.astro';
---

<Base>
  <PageHeader
    headline="Let's talk about how your business runs."
    subheadline="30 minutes. No pitch, no demo, no obligation. We'll ask about your operations and tell you where we think time and money are being lost."
  />
  <ContactForm />
  <CTAStrip
    headline="Not sure yet? See what manual work is costing your business."
    buttonText="Try the calculator"
    buttonHref="/calculator"
  />
</Base>
